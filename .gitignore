tools/pc-ai-server/.env

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# MNN 完整源码树（体积大；用 tools/setup_mnn_headers.ps1 克隆到本地，勿进仓库）
/third_party/MNN/

# MNN 预编译 .so（构建时由 Gradle 下载；亦可手动放入 jniLibs/arm64-v8a）
/android/app/src/main/jniLibs/**/*.so
/android/app/src/main/jniLibs/**/.mnn_3.4.1_ok
