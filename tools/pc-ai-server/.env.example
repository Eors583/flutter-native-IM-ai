AIIM_HOST=0.0.0.0
AIIM_PORT=8080

# ollama | openai | mock
# mock：不依赖任何大模型，直接回显，用于先把链路跑通
AIIM_BACKEND=ollama

# Ollama
AIIM_OLLAMA_URL=http://127.0.0.1:11434
AIIM_OLLAMA_MODEL=llama3.2

# OpenAI-compatible
AIIM_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
AIIM_OPENAI_API_KEY=
AIIM_OPENAI_MODEL=gpt-4o-mini

# System prompt injected for every answer
AIIM_SYSTEM_PROMPT=你是一个温柔、耐心、简洁的助手，用中文回答。

